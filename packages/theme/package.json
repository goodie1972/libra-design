{
  "name": "@libra-design/theme",
  "version": "0.1.2",
  "description": "Libra 极致审美的设计语言，专为Go/Rust量身定制。双主题混合引擎 — gamma-aware 暗色↔亮色无缝过渡。",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "libra",
    "theme",
    "dark-mode",
    "light-mode",
    "css-variables",
    "color-interpolation"
  ],
  "license": "MIT",
  "dependencies": {
    "@libra-design/tokens": "^0.1.0"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}