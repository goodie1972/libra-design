{
  "version": "1.0",
  "description": "Libra 设计系统 — 语言无关的设计令牌。所有语言绑定（Go/Rust/TS）均从本文件派生。",
  "colors": {
    "semantic": {
      "up": "#ef5350",
      "down": "#26a69a",
      "flat": "#9e9e9e",
      "up-bg": "rgba(239, 83, 80, 0.08)",
      "up-light": "#ff8a80",
      "down-bg": "rgba(38, 166, 154, 0.08)",
      "down-light": "#64d8cb",
      "ma5": "#f8b500",
      "ma10": "#4a6cf7",
      "ma20": "#9c27b0",
      "ma60": "#009688",
      "ma120": "#ff7043",
      "ma250": "#78909c",
      "success": "#34a853",
      "warning": "#fbbc04",
      "error": "#ea4335"
    },
    "dark_endpoint": {
      "bg-root": "#0c0c0e",
      "bg-main": "#0c0c0e",
      "bg-sidebar": "#0c0c0e",
      "bg-card": "#121214",
      "bg-card-hover": "#18181b",
      "bg-input": "#18181b",
      "bg-chart": "#0c0c0e",
      "bg-sub-panel": "#121214",
      "border-main": "#1e1e22",
      "border-sub": "#161618",
      "border-input": "#1e1e22",
      "text-primary": "#e8e8ed",
      "text-secondary": "#9a9aa0",
      "text-tertiary": "#63636a",
      "accent": "#4a6cf7",
      "accent-hover": "#5d7cf9",
      "grid-line": "#18191c"
    },
    "light_endpoint": {
      "bg-root": "#f5f5f7",
      "bg-main": "#f5f5f7",
      "bg-sidebar": "#f5f5f7",
      "bg-card": "#ffffff",
      "bg-card-hover": "#f0f0f2",
      "bg-input": "#eaeaee",
      "bg-chart": "#f5f5f7",
      "bg-sub-panel": "#ffffff",
      "border-main": "#d4d4d8",
      "border-sub": "#e8e8ec",
      "border-input": "#d4d4d8",
      "text-primary": "#0d0d12",
      "text-secondary": "#555566",
      "text-tertiary": "#8e8e98",
      "accent": "#533afd",
      "accent-hover": "#4527e0",
      "grid-line": "#e8ecf0"
    },
    "chart": {
      "grid-line-dark": "#18191c",
      "grid-line-light": "#e8ecf0",
      "vol-up": "rgba(239, 83, 80, 0.55)",
      "vol-down": "rgba(38, 166, 154, 0.55)",
      "hist-up": "rgba(239, 83, 80, 0.7)",
      "hist-down": "rgba(38, 166, 154, 0.7)"
    }
  },
  "typography": {
    "families": {
      "display": "\"Inter Display\", -apple-system, \"SF Pro Display\", \"PingFang SC\", sans-serif",
      "body": "\"Inter\", -apple-system, \"SF Pro Text\", \"PingFang SC\", \"Microsoft YaHei\", sans-serif",
      "mono": "\"JetBrains Mono\", \"SF Mono\", \"Cascadia Code\", \"Noto Sans Mono\", monospace"
    },
    "sizes": {
      "xs": 10,
      "sm": 12,
      "base": 13,
      "md": 14,
      "lg": 16,
      "xl": 20,
      "2xl": 24,
      "3xl": 32,
      "4xl": 40
    },
    "weights": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "tracking": {
      "display": -0.04,
      "title": -0.03,
      "subtitle": -0.02,
      "body": -0.01,
      "label": 0.01
    },
    "leading": {
      "tight": 1.2,
      "normal": 1.5,
      "loose": 1.75
    }
  },
  "spacing": {
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 24,
    "6": 32,
    "7": 48,
    "8": 64
  },
  "radii": {
    "sm": 4,
    "md": 8,
    "lg": 10,
    "xl": 12,
    "full": 9999,
    "btn": 8,
    "card": 10
  },
  "component": {
    "card-shadow": "none",
    "card-border": "1px solid var(--border-main)"
  }
}