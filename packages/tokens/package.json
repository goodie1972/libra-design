{
  "name": "@libra-design/tokens",
  "version": "0.1.4",
  "description": "Libra 极致审美的设计语言，专为Go/Rust量身定制。设计令牌 — 语言无关 JSON，Go/Rust/TS 三语言绑定。CSS 变量 + TypeScript 类型定义。",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch && cp src/index.css dist/index.css",
    "build": "vite build && cp src/index.css dist/index.css",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "libra",
    "design-tokens",
    "css-variables",
    "financial",
    "dark-theme",
    "go",
    "rust",
    "multi-language",
    "theme"
  ],
  "license": "MIT",
  "devDependencies": {
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.1"
  }
}
