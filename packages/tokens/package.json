{
  "name": "@libra-design/tokens",
  "version": "0.1.3",
  "description": "Libra \u6781\u81f4\u5ba1\u7f8e\u7684\u8bbe\u8ba1\u8bed\u8a00\uff0c\u4e13\u4e3aGo/Rust\u91cf\u8eab\u5b9a\u5236\u3002\u8bbe\u8ba1\u4ee4\u724c \u2014 CSS \u53d8\u91cf + TypeScript \u7c7b\u578b\u5b9a\u4e49\u3002",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch && cp src/index.css dist/index.css",
    "build": "vite build && cp src/index.css dist/index.css",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "libra",
    "design-tokens",
    "css-variables",
    "financial",
    "dark-theme",
    "go",
    "rust",
    "multi-language",
    "language-agnostic"
  ],
  "license": "MIT",
  "devDependencies": {
    "vite": "^5.4.0"
  }
}