{
  "name": "libra",
  "version": "0.1.0",
  "private": true,
  "description": "Libra Design System — Go/Rust 原生 + React 多语言金融设计系统。一份设计令牌，全语言消费。JS 设计系统是红海，Go/Rust 是蓝海。",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:tokens": "npm run build -w packages/tokens",
    "build:theme": "npm run build -w packages/theme",
    "dev:tokens": "npm run dev -w packages/tokens",
    "dev:theme": "npm run dev -w packages/theme",
    "publish:tokens": "npm publish -w packages/tokens",
    "publish:theme": "npm publish -w packages/theme",
    "version:patch": "npm version patch --workspaces",
    "version:minor": "npm version minor --workspaces"
  },
  "engines": {
    "node": ">=18"
  }
}
